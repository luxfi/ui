{
  "name": "@luxfi/contracts",
  "version": "0.1.0",
  "description": "Contract ABIs and per-chain addresses for Lux ecosystem",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Lux Partners",
    "url": "https://lux.network"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luxfi/ui.git",
    "directory": "packages/contracts"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./addresses": {
      "types": "./dist/addresses.d.ts",
      "import": "./dist/addresses.js",
      "require": "./dist/addresses.cjs"
    },
    "./abis": {
      "types": "./dist/abis.d.ts",
      "import": "./dist/abis.js",
      "require": "./dist/abis.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
