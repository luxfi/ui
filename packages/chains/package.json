{
  "name": "@luxfi/chains",
  "version": "0.1.0",
  "description": "Lux chain definitions, wagmi config, and explorer API client",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Lux Partners",
    "url": "https://lux.network"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luxfi/ui.git",
    "directory": "packages/chains"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./chains": {
      "types": "./dist/chains.d.ts",
      "import": "./dist/chains.js",
      "require": "./dist/chains.cjs"
    },
    "./wagmi": {
      "types": "./dist/wagmi.d.ts",
      "import": "./dist/wagmi.js",
      "require": "./dist/wagmi.cjs"
    },
    "./explorer": {
      "types": "./dist/explorer.d.ts",
      "import": "./dist/explorer.js",
      "require": "./dist/explorer.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "viem": "^2.0.0"
  },
  "peerDependencies": {
    "wagmi": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "wagmi": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "wagmi": "^2.0.0"
  }
}
