{
  "name": "@hanzo/gui-focus-guard",
  "version": "2.0.4",
  "source": "src/index.ts",
  "type": "module",
  "files": [
    "src",
    "types",
    "dist"
  ],
  "sideEffects": true,
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "./types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./types/index.d.ts",
      "react-native": "./dist/esm/index.native.js",
      "browser": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "hanzo-gui-build",
    "watch": "hanzo-gui-build --watch",
    "clean": "hanzo-gui-build clean",
    "clean:build": "hanzo-gui-build clean:build"
  },
  "dependencies": {
    "@hanzo/gui-compose-refs": "2.0.1",
    "@hanzo/gui-use-event": "2.0.1"
  },
  "devDependencies": {
    "@hanzo/gui-build": "2.0.1",
    "react": ">=19"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "module:jsx": "dist/jsx"
}
