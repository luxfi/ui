    "clean:build": "hanzo-gui-build clean:build"
  },
  "dependencies": {
    "@hanzo/gui-animate-presence": "workspace:*",
    "@hanzo/gui-collection": "workspace:*",
    "@hanzo/gui-compose-refs": "workspace:*",
    "@hanzo/gui-constants": "workspace:*",
    "@hanzo/gui-core": "workspace:*",
    "@hanzo/gui-create-context": "workspace:*",
    "@hanzo/gui-dismissable": "workspace:*",
    "@hanzo/gui-helpers": "workspace:*",
    "@hanzo/gui-native": "workspace:*",
    "@hanzo/gui-polyfill-dev": "workspace:*",
    "@hanzo/gui-portal": "workspace:*",
    "@hanzo/gui-stacks": "workspace:*",
    "@hanzo/gui-start-transition": "workspace:*",
    "@hanzo/gui-text": "workspace:*",
    "@hanzo/gui-use-controllable-state": "workspace:*",
    "@hanzo/gui-visually-hidden": "workspace:*"
  },
  "devDependencies": {
    "@hanzo/gui-build": "workspace:*",
    "react": ">=19",
    "react-native": "0.83.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "module:jsx": "dist/jsx"
