  "dependencies": {
    "@hanzo/gui-compose-refs": "2.0.1",
    "@hanzo/gui-constants": "2.0.1",
    "@hanzo/gui-core": "2.0.1",
    "@hanzo/gui-create-context": "2.0.1",
    "@hanzo/gui-focusable": "2.0.1",
    "@hanzo/gui-get-token": "2.0.1",
    "@hanzo/gui-helpers": "2.0.1",
    "@hanzo/gui-label": "2.0.1",
    "@hanzo/gui-radio-headless": "2.0.1",
    "@hanzo/gui-roving-focus": "2.0.1",
    "@hanzo/gui-stacks": "2.0.1",
    "@hanzo/gui-use-controllable-state": "2.0.1",
    "@hanzo/gui-use-previous": "2.0.1"
  },
  "devDependencies": {
    "@hanzo/gui-build": "2.0.1",
    "react": ">=19"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "module:jsx": "dist/jsx",
  "removeSideEffects": true
