{
  "name": "@hanzo/gui-portal",
  "version": "2.0.0-rc.29",
  "source": "src/index.ts",
  "files": [
    "src",
    "types",
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "dist/cjs",
  "module": "dist/esm",
  "types": "./types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./types/index.d.ts",
      "react-native": "./dist/esm/index.native.js",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "hanzo-gui-build",
    "watch": "hanzo-gui-build --watch",
    "clean": "hanzo-gui-build clean",
    "clean:build": "hanzo-gui-build clean:build"
  },
  "dependencies": {
    "@hanzo/gui-constants": "2.0.0-rc.29",
    "@hanzo/gui-core": "2.0.0-rc.29",
    "@hanzo/gui-native": "2.0.0-rc.29",
    "@hanzo/gui-start-transition": "2.0.0-rc.29",
    "@hanzo/gui-use-event": "2.0.0-rc.29",
    "@hanzo/gui-web": "2.0.0-rc.29",
    "@hanzo/gui-z-index-stack": "workspace:*"
  },
  "devDependencies": {
    "@hanzo/gui-build": "2.0.0-rc.29",
    "react": ">=19",
    "react-dom": "*",
    "react-native": "0.83.2"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": "*",
    "react-native": "*"
  }
}
