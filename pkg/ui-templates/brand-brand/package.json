{
  "name": "@brand/brand",
  "version": "1.0.0",
  "description": "Brand identity package - logos, colors, and design system",
  "author": "Brand Team",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "style"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./logo": {
      "types": "./dist/logo/index.d.ts",
      "import": "./dist/logo/index.mjs",
      "require": "./dist/logo/index.js"
    },
    "./colors": {
      "types": "./dist/colors/index.d.ts",
      "import": "./dist/colors/index.mjs",
      "require": "./dist/colors/index.js"
    },
    "./system": {
      "types": "./dist/system/index.d.ts",
      "import": "./dist/system/index.mjs",
      "require": "./dist/system/index.js"
    },
    "./style/*": "./style/*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  }
}
