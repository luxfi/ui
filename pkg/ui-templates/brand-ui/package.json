{
  "name": "@brand/ui",
  "version": "1.0.0",
  "description": "UI library for Brand - built on @hanzo/ui",
  "author": "Brand Team",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./system": {
      "types": "./dist/system/index.d.ts",
      "import": "./dist/system/index.mjs",
      "require": "./dist/system/index.js"
    },
    "./tailwind.config.brand": {
      "types": "./dist/tailwind.config.brand.d.ts",
      "import": "./dist/tailwind.config.brand.mjs",
      "require": "./dist/tailwind.config.brand.js"
    }
  },
  "peerDependencies": {
    "@brand/brand": ">=1.0.0",
    "@hanzo/ui": ">=5.0.0",
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  }
}
